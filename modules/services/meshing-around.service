# meshing-around service — Meshtastic BBS bot
#
# Requires the meshing-around package in your packages list:
#
#   packages = with localPkgs; [ meshing-around ];
#
# To enable, import this file and set the option:
#
#   imports = [
#     ./hardware/pico-mini-b.nix
#     ./modules/services/meshing-around.service
#   ];
#
#   services.user.meshing-around.enable = true;
#
# Edit the config before flashing:
#   /etc/meshing-around/config.ini
#
# Logs are written to /var/log/meshing-around.log

{ pkgs, ... }:

{
  services.user.meshing-around = {
    enable = pkgs.lib.mkDefault false;   # set to true in your configuration.nix to start the bot
    action = "respawn";
    script = ''
      LOG=/var/log/meshing-around.log
      echo "$(date): starting meshing-around" >> "$LOG"
      exec /bin/meshing-around >> "$LOG" 2>&1
    '';
  };
}
